@page "/"
@rendermode InteractiveWebAssembly
@implements IDisposable
@inject IUserService UserService
@inject IOtpService OtpService
@inject IPresentationService PresentationService
@inject IIframeInteropService IframeInterop
@inject IAppEnvironmentService Environment
@inject NavigationManager Nav
@inject PayUnicard.Registration.Iframe.Client.Services.RegistrationState State

<div class="reg-page">
    <div class="reg-card">
        <div class="reg-logo">
            <img class="reg-logo-mark" src="/images/payunicard_en.svg" alt="PayUnicard" />
        </div>

        @if (step == 1)
        {
            <div class="reg-form-shell">
                <h1 class="reg-title reg-title-centered">Register online</h1>

                @if (Environment.IsMockMode)
                {
                    <div class="alert alert-info">
                        Development mode is enabled. OTP and KYC can run against mock services.
                    </div>
                }

                <p class="reg-note">Only Latin / Georgian letters are allowed.</p>
                <p class="reg-note reg-note-spaced">Please fill registration data in English where required.</p>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger">@errorMessage</div>
                }

                <div class="form-stack">
                    <div class="field">
                        <label for="firstName">First Name</label>
                        <input id="firstName" @bind="model.Name" @bind:event="oninput" />
                        @if (!string.IsNullOrEmpty(nameError))
                        {
                            <div class="field-error">@nameError</div>
                        }
                    </div>

                    <div class="field">
                        <label for="lastName">Last Name</label>
                        <input id="lastName" @bind="model.Surname" @bind:event="oninput" />
                        @if (!string.IsNullOrEmpty(surnameError))
                        {
                            <div class="field-error">@surnameError</div>
                        }
                    </div>

                    <div class="field">
                        <label for="mobileNumber">Mobile Number</label>
                        <div class="phone-row">
                            <select @bind="selectedCountryCode" aria-label="Phone country code">
                                @foreach (var phoneOption in phoneCountryCodes)
                                {
                                    <option value="@phoneOption.Value">@phoneOption.Text</option>
                                }
                            </select>
                            <input id="mobileNumber"
                                   type="tel"
                                   @bind="phoneNumber"
                                   @bind:event="oninput"
                                   @onblur="CheckPhoneAsync"
                                   class="@PhoneClass" />
                        </div>
                        @if (!string.IsNullOrEmpty(phoneMessage))
                        {
                            <div class="@(phoneError ? "field-error" : "field-hint ok-hint")">@phoneMessage</div>
                        }
                    </div>

                    <div class="field">
                        <label for="email">Email</label>
                        <input id="email"
                               type="email"
                               @bind="model.UserName"
                               @bind:event="oninput"
                               @onblur="CheckUsernameAsync"
                               class="@UsernameClass" />
                        @if (!string.IsNullOrEmpty(usernameMessage))
                        {
                            <div class="@(usernameError ? "field-error" : "field-hint ok-hint")">@usernameMessage</div>
                        }
                    </div>

                    <div class="field">
                        <label for="birthDate">Birth Date</label>
                        <input id="birthDate" type="date" value="@BirthDateInputValue" @onchange="OnBirthDateChanged" />
                        @if (!string.IsNullOrEmpty(birthDateError))
                        {
                            <div class="field-error">@birthDateError</div>
                        }
                    </div>

                    <div class="field">
                        <label for="citizenship">Citizenship</label>
                        <select id="citizenship" value="@model.CitizenshipCountryID" @onchange="HandleCitizenshipChanged">
                            <option value="0">Select citizenship</option>
                            @foreach (var country in citizenshipCountries)
                            {
                                <option value="@country.CountryID">@country.CountryName</option>
                            }
                        </select>
                    </div>

                    <div class="field">
                        <label for="personalDocument">@PersonalDocumentLabel</label>
                        <input id="personalDocument"
                               @bind="model.PersonalId"
                               @bind:event="oninput"
                               @onblur="CheckPersonalIdAsync"
                               class="@PersonalIdClass" />
                        @if (!string.IsNullOrEmpty(personalIdMessage))
                        {
                            <div class="@(personalIdError ? "field-error" : "field-hint ok-hint")">@personalIdMessage</div>
                        }
                    </div>

                    <div class="form-grid form-grid-tight">
                        <div class="field">
                            <label for="password">Password</label>
                            <div class="field-with-action">
                                <input id="password"
                                       type="@(passwordVisible ? "text" : "password")"
                                       value="@model.Password"
                                       @oninput="CheckPasswordStrength" />
                                <button class="field-action"
                                        type="button"
                                        @onclick='() => passwordVisible = !passwordVisible'
                                        aria-label="Toggle password visibility">
                                    @(passwordVisible ? "Hide" : "Show")
                                </button>
                            </div>
                        </div>

                        <div class="field">
                            <label for="confirmPassword">Repeat Password</label>
                            <div class="field-with-action">
                                <input id="confirmPassword"
                                       type="@(confirmPasswordVisible ? "text" : "password")"
                                       @bind="confirmPassword"
                                       @bind:event="oninput" />
                                <button class="field-action"
                                        type="button"
                                        @onclick='() => confirmPasswordVisible = !confirmPasswordVisible'
                                        aria-label="Toggle confirm password visibility">
                                    @(confirmPasswordVisible ? "Hide" : "Show")
                                </button>
                            </div>
                            @if (!string.IsNullOrEmpty(confirmPasswordError))
                            {
                                <div class="field-error">@confirmPasswordError</div>
                            }
                        </div>
                    </div>

                    <div class="password-checklist">
                        <div class="password-rule @(model.Password.Length >= 8 ? "valid" : string.Empty)">Minimum 8 characters</div>
                        <div class="password-rule @(model.Password.Any(char.IsUpper) ? "valid" : string.Empty)">At least one uppercase letter</div>
                        <div class="password-rule @(model.Password.Any(char.IsLower) ? "valid" : string.Empty)">At least one lowercase letter</div>
                        <div class="password-rule @(model.Password.Any(char.IsDigit) ? "valid" : string.Empty)">At least one number</div>
                        <div class="password-rule @(model.Password.Any(IsSupportedSpecialCharacter) ? "valid" : string.Empty)">At least one special character</div>
                    </div>

                    <div class="checkbox-group">
                        <label class="checkbox-row">
                            <input type="checkbox" @bind="termsAccepted" />
                            <span>
                                I agree to the
                                <a href="/info-page/terms-of-use?open=0" target="_blank" rel="noreferrer"> terms of service</a>.
                            </span>
                        </label>
                        <label class="checkbox-row">
                            <input type="checkbox" @bind="webTermsAccepted" />
                            <span>
                                I agree to the
                                <a href="/info-page/terms-of-use?open=4" target="_blank" rel="noreferrer"> web service terms</a>.
                            </span>
                        </label>
                    </div>

                    <div class="button-row">
                        <button class="btn btn-outline" type="button" @onclick="ClearForm">Clear</button>
                        <button class="btn btn-primary" type="button" @onclick="GoToOtpAsync" disabled="@(!CanProceed)">
                            @if (loading)
                            {
                                <span class="spinner"></span>
                            }
                            <span>Sign up</span>
                        </button>
                    </div>
                </div>

                <p class="reg-footer-link">Already have an account? <a href="/iframe/login">Login</a></p>
            </div>
        }
        else if (step == 2)
        {
            <div class="reg-form-shell reg-form-shell-narrow">
                <h1 class="reg-title reg-title-centered">OTP Confirmation</h1>
                <p class="reg-subtitle reg-subtitle-centered">
                    Enter the 4 digit code sent to <strong>@model.Phone</strong>.
                </p>

                @if (Environment.IsMockMode)
                {
                    <div class="alert alert-info">Mock OTP code: <code>1234</code></div>
                }

                <div class="otp-row">
                    @for (var i = 0; i < otpDigits.Length; i++)
                    {
                        var otpIndex = i;
                        <input maxlength="1"
                               inputmode="numeric"
                               value="@otpDigits[otpIndex]"
                               @oninput="e => OnOtpDigitChanged(otpIndex, e)" />
                    }
                </div>

                @if (!string.IsNullOrEmpty(otpErrorMessage))
                {
                    <div class="alert alert-danger">@otpErrorMessage</div>
                }

                <div class="otp-timer">
                    @if (secondsLeft > 0)
                    {
                        <span>Send again <span>@secondsLeft</span></span>
                    }
                    else
                    {
                        <button class="btn-link" type="button" @onclick="ResendOtpAsync">Send again</button>
                    }
                </div>

                <div class="button-row">
                    <button class="btn btn-outline" type="button" @onclick="BackToRegistration">Cancel</button>
                    <button class="btn btn-primary" type="button" @onclick="VerifyOtpAsync" disabled="@(loading || otpDigits.Any(string.IsNullOrWhiteSpace))">
                        @if (loading)
                        {
                            <span class="spinner"></span>
                        }
                        <span>Confirm</span>
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="success-screen">
                <div class="success-icon">OK</div>
                <h3>Registration complete</h3>
                <p>Your pre-registration is complete. Continue to identification to finish onboarding.</p>
                <button class="btn btn-primary" type="button" @onclick="GoToIdentification">
                    Continue to Identification
                </button>
            </div>
        }
    </div>
</div>

@code {
    private sealed record PhoneOption(string Value, string Text);

    private readonly List<PhoneOption> phoneCountryCodes =
    [
        new("+995", "GE +995"),
        new("+1", "US +1"),
        new("+44", "UK +44"),
        new("+49", "DE +49")
    ];

    private readonly string[] otpDigits = new string[4];
    private readonly List<CitizenshipCountry> citizenshipCountries = [];
    private UserPreRegistrationRequest model = new()
    {
        CitizenshipCountryID = 1,
        IsApplyTerms = "1"
    };

    private int step = 1;
    private bool loading;
    private bool usernameError;
    private bool phoneError;
    private bool personalIdError;
    private bool termsAccepted;
    private bool webTermsAccepted;
    private bool passwordVisible;
    private bool confirmPasswordVisible;
    private int secondsLeft;
    private DateOnly? birthDateValue;
    private string confirmPassword = string.Empty;
    private string selectedCountryCode = "+995";
    private string phoneNumber = string.Empty;
    private string errorMessage = string.Empty;
    private string usernameMessage = string.Empty;
    private string phoneMessage = string.Empty;
    private string personalIdMessage = string.Empty;
    private string otpErrorMessage = string.Empty;
    private string nameError = string.Empty;
    private string surnameError = string.Empty;
    private string birthDateError = string.Empty;
    private string confirmPasswordError = string.Empty;
    private string? refId;
    private string? refName;
    private System.Threading.Timer? countdownTimer;
    private bool iframeLoadedNotified;

    private CitizenshipCountry? SelectedCitizenship
        => citizenshipCountries.FirstOrDefault(country => country.CountryID == model.CitizenshipCountryID);

    private bool IsGeorgianCitizen
        => string.Equals(SelectedCitizenship?.CountryCode, "GE", StringComparison.OrdinalIgnoreCase);

    private string PersonalDocumentLabel => IsGeorgianCitizen ? "ID Number" : "Passport Number";
    private string UsernameClass => usernameError ? "error" : usernameMessage.Length > 0 ? "success" : string.Empty;
    private string PersonalIdClass => personalIdError ? "error" : personalIdMessage.Length > 0 ? "success" : string.Empty;
    private string PhoneClass => phoneError ? "error" : phoneMessage.Length > 0 ? "success" : string.Empty;
    private string BirthDateInputValue => birthDateValue?.ToString("yyyy-MM-dd") ?? string.Empty;

    private bool CanProceed =>
        !loading &&
        ValidateName(model.Name, out _) &&
        ValidateName(model.Surname, out _) &&
        ValidateEmail(model.UserName) &&
        !usernameError &&
        !phoneError &&
        !personalIdError &&
        !string.IsNullOrWhiteSpace(phoneNumber) &&
        ValidatePassword(model.Password) &&
        ValidateBirthDate(out _) &&
        ValidatePersonalDocument(out _) &&
        confirmPassword == model.Password &&
        termsAccepted &&
        webTermsAccepted;

    protected override async Task OnInitializedAsync()
    {
        var query = ParseQuery(new Uri(Nav.Uri).Query);
        query.TryGetValue("refId", out refId);
        query.TryGetValue("refName", out refName);

        try
        {
            var countries = await PresentationService.GetCitizenshipCountriesAsync();
            if (countries?.Countries is { Count: > 0 })
            {
                citizenshipCountries.AddRange(countries.Countries);
                if (model.CitizenshipCountryID == 0)
                {
                    model.CitizenshipCountryID = citizenshipCountries[0].CountryID;
                }
            }
        }
        catch
        {
            // Keep the page usable even if presentation data is temporarily unavailable.
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || iframeLoadedNotified)
        {
            return;
        }

        try
        {
            await IframeInterop.NotifyParentAsync("iframe.loaded", new { step = "register", mode = Environment.App.Mode });
            iframeLoadedNotified = true;
        }
        catch (InvalidOperationException)
        {
            // Ignore prerender-time JS interop failures. The component will render again in the browser.
        }
    }

    private void HandleCitizenshipChanged(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var countryId))
        {
            model.CitizenshipCountryID = countryId;
        }

        model.PersonalId = string.Empty;
        personalIdError = false;
        personalIdMessage = string.Empty;
    }

    private async Task CheckUsernameAsync()
    {
        usernameError = false;
        usernameMessage = string.Empty;

        if (!ValidateEmail(model.UserName))
        {
            usernameError = true;
            usernameMessage = "Enter a valid email address.";
            return;
        }

        var result = await UserService.CheckUserPreRegistrationAsync(new CheckUserRequest
        {
            UserName = model.UserName.Trim()
        });

        usernameError = result?.UserNameExists == true;
        usernameMessage = usernameError ? "This email is already registered." : "Email is available.";
    }

    private async Task CheckPhoneAsync()
    {
        phoneError = false;
        phoneMessage = string.Empty;

        var normalizedPhone = NormalizePhone();
        if (string.IsNullOrWhiteSpace(normalizedPhone))
        {
            return;
        }

        var result = await UserService.CheckUserPreRegistrationAsync(new CheckUserRequest
        {
            Phone = normalizedPhone
        });

        phoneError = result?.PhoneExists == true;
        phoneMessage = phoneError ? "This phone number is already registered." : "Phone number is available.";
    }

    private async Task CheckPersonalIdAsync()
    {
        personalIdError = false;
        personalIdMessage = string.Empty;

        if (!ValidatePersonalDocument(out var validationError))
        {
            personalIdError = true;
            personalIdMessage = validationError;
            return;
        }

        var result = await UserService.CheckUserPreRegistrationAsync(new CheckUserRequest
        {
            PersonalID = model.PersonalId.Trim()
        });

        personalIdError = result?.PersonalIDExists == true;
        personalIdMessage = personalIdError ? "This personal document is already registered." : "Document number is available.";
    }

    private void CheckPasswordStrength(ChangeEventArgs args)
    {
        model.Password = args.Value?.ToString() ?? string.Empty;
        confirmPasswordError = confirmPassword == model.Password ? string.Empty : "Passwords do not match.";
    }

    private async Task GoToOtpAsync()
    {
        errorMessage = string.Empty;
        nameError = ValidateName(model.Name, out var firstNameError) ? string.Empty : firstNameError;
        surnameError = ValidateName(model.Surname, out var lastNameError) ? string.Empty : lastNameError;
        birthDateError = ValidateBirthDate(out var dateError) ? string.Empty : dateError;
        confirmPasswordError = confirmPassword == model.Password ? string.Empty : "Passwords do not match.";

        if (!ValidatePersonalDocument(out var personalDocumentError))
        {
            personalIdError = true;
            personalIdMessage = personalDocumentError;
        }

        if (!CanProceed)
        {
            errorMessage = "Please correct the highlighted fields before continuing.";
            return;
        }

        loading = true;

        model.Phone = NormalizePhone();
        model.PhoneCountryCode = selectedCountryCode.TrimStart('+');
        model.BirthDate = birthDateValue?.ToString("yyyy-MM-dd") ?? string.Empty;
        model.ConfirmPassword = confirmPassword;
        model.RefId = refId;
        model.RefName = refName;

        try
        {
            var token = await IframeInterop.GetRecaptchaTokenAsync("send_phone_otp");
            await OtpService.SendPhoneOtpAsync(
                new SendOtpRequest { Phone = model.Phone },
                string.IsNullOrWhiteSpace(token) ? "mock-token" : token);

            StartCountdown();
            step = 2;
            await IframeInterop.NotifyParentAsync("registration.otp.sent", new { phone = model.Phone });
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to send OTP: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void ClearForm()
    {
        model = new UserPreRegistrationRequest
        {
            CitizenshipCountryID = citizenshipCountries.FirstOrDefault()?.CountryID ?? 1,
            IsApplyTerms = "1"
        };

        birthDateValue = null;
        confirmPassword = string.Empty;
        phoneNumber = string.Empty;
        usernameError = false;
        phoneError = false;
        personalIdError = false;
        termsAccepted = false;
        webTermsAccepted = false;
        passwordVisible = false;
        confirmPasswordVisible = false;
        errorMessage = string.Empty;
        usernameMessage = string.Empty;
        phoneMessage = string.Empty;
        personalIdMessage = string.Empty;
        otpErrorMessage = string.Empty;
        nameError = string.Empty;
        surnameError = string.Empty;
        birthDateError = string.Empty;
        confirmPasswordError = string.Empty;
    }

    private void BackToRegistration()
    {
        otpErrorMessage = string.Empty;
        step = 1;
    }

    private void OnBirthDateChanged(ChangeEventArgs args)
    {
        birthDateError = string.Empty;
        birthDateValue = DateOnly.TryParse(args.Value?.ToString(), out var parsedDate) ? parsedDate : null;
    }

    private void OnOtpDigitChanged(int index, ChangeEventArgs args)
    {
        var value = args.Value?.ToString() ?? string.Empty;
        otpDigits[index] = value.Where(char.IsDigit).TakeLast(1).Select(ch => ch.ToString()).FirstOrDefault() ?? string.Empty;
        otpErrorMessage = string.Empty;
    }

    private async Task ResendOtpAsync()
    {
        otpErrorMessage = string.Empty;

        var token = await IframeInterop.GetRecaptchaTokenAsync("resend_phone_otp");
        await OtpService.SendPhoneOtpAsync(
            new SendOtpRequest { Phone = model.Phone },
            string.IsNullOrWhiteSpace(token) ? "mock-token" : token);

        StartCountdown();
    }

    private async Task VerifyOtpAsync()
    {
        loading = true;
        otpErrorMessage = string.Empty;

        try
        {
            var otp = string.Concat(otpDigits);
            var otpResult = await OtpService.SubmitPhoneOtpAsync(new SubmitOtpRequest
            {
                Otp = otp,
                Phone = model.Phone
            });

            if (string.IsNullOrWhiteSpace(otpResult?.OtpGuid))
            {
                otpErrorMessage = "OTP verification failed.";
                return;
            }

            model.OtpGuid = otpResult.OtpGuid;
            var result = await UserService.UserPreRegistrationAsync(model);

            if (result?.Success != true)
            {
                otpErrorMessage = "Pre-registration was rejected by the API.";
                return;
            }

            State.PreRegistration = model;
            step = 3;
            countdownTimer?.Dispose();
            await IframeInterop.NotifyParentAsync("registration.pre.completed", new { username = model.UserName });
        }
        catch (Exception ex)
        {
            otpErrorMessage = $"Verification failed: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void GoToIdentification() => Nav.NavigateTo("/identification");

    private void StartCountdown()
    {
        secondsLeft = 60;
        countdownTimer?.Dispose();
        countdownTimer = new System.Threading.Timer(_ =>
        {
            if (secondsLeft > 0)
            {
                secondsLeft--;
            }
            else
            {
                countdownTimer?.Dispose();
            }

            InvokeAsync(StateHasChanged);
        }, null, 1000, 1000);
    }

    private string NormalizePhone()
    {
        var digits = new string(phoneNumber.Where(char.IsDigit).ToArray());
        return string.IsNullOrWhiteSpace(digits)
            ? string.Empty
            : $"{selectedCountryCode.TrimStart('+')}{digits}";
    }

    private static bool ValidateEmail(string? email)
    {
        if (string.IsNullOrWhiteSpace(email))
        {
            return false;
        }

        try
        {
            _ = new System.Net.Mail.MailAddress(email.Trim());
            return true;
        }
        catch
        {
            return false;
        }
    }

    private static bool ValidateName(string? value, out string error)
    {
        error = string.Empty;
        if (string.IsNullOrWhiteSpace(value))
        {
            error = "This field is required.";
            return false;
        }

        if (!System.Text.RegularExpressions.Regex.IsMatch(value.Trim(), @"^[\p{L}\s'-]+$"))
        {
            error = "Only letters, spaces, apostrophes and dashes are allowed.";
            return false;
        }

        return true;
    }

    private bool ValidateBirthDate(out string error)
    {
        error = string.Empty;
        if (birthDateValue is null)
        {
            error = "Birth date is required.";
            return false;
        }

        var today = DateOnly.FromDateTime(DateTime.UtcNow);
        var age = today.Year - birthDateValue.Value.Year;
        if (birthDateValue.Value > today.AddYears(-age))
        {
            age--;
        }

        if (age is < 18 or > 150)
        {
            error = "Age must be between 18 and 150.";
            return false;
        }

        return true;
    }

    private bool ValidatePersonalDocument(out string error)
    {
        error = string.Empty;
        if (model.CitizenshipCountryID <= 0)
        {
            error = "Citizenship is required.";
            return false;
        }

        if (string.IsNullOrWhiteSpace(model.PersonalId))
        {
            error = $"{PersonalDocumentLabel} is required.";
            return false;
        }

        var trimmedValue = model.PersonalId.Trim();
        if (IsGeorgianCitizen)
        {
            if (trimmedValue.Length != 11 || !trimmedValue.All(char.IsDigit))
            {
                error = "Georgian personal ID must contain exactly 11 digits.";
                return false;
            }

            return true;
        }

        if (trimmedValue.Length is < 6 or > 20)
        {
            error = "Passport number must be between 6 and 20 characters.";
            return false;
        }

        return true;
    }

    private static bool ValidatePassword(string password)
        => password.Length >= 8
           && password.Any(char.IsUpper)
           && password.Any(char.IsLower)
           && password.Any(char.IsDigit)
           && password.Any(IsSupportedSpecialCharacter);

    private static bool IsSupportedSpecialCharacter(char value)
        => "!#$%^&*()-_=+[]{};:,.?/\\|~".Contains(value);

    private static Dictionary<string, string> ParseQuery(string queryString)
    {
        var result = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        if (string.IsNullOrWhiteSpace(queryString))
        {
            return result;
        }

        foreach (var pair in queryString.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var parts = pair.Split('=', 2);
            var key = Uri.UnescapeDataString(parts[0]);
            var value = parts.Length > 1 ? Uri.UnescapeDataString(parts[1]) : string.Empty;
            result[key] = value;
        }

        return result;
    }

    public void Dispose() => countdownTimer?.Dispose();
}
