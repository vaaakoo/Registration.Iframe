@page "/success"
@rendermode InteractiveWebAssembly
@inject IIframeInteropService IframeInterop
@inject NavigationManager Nav

<div class="reg-page">
    <div class="reg-card reg-card-wide">
        <div class="reg-logo">
            <img class="reg-logo-mark" src="/images/payunicard_en.svg" alt="PayUnicard" />
        </div>

        <div class="wizard-shell">
            <h1 class="reg-title wizard-title">Identification</h1>

            <div class="wizard-content-shell">
                <div class="waiting-panel">
                    <div class="waiting-badge">
                        <span></span>
                    </div>
                    <p class="waiting-title">Your application is under review</p>
                    <p class="waiting-copy">
                        Your identity verification has been submitted successfully.
                        We will notify you once the compliance review is finished.
                    </p>
                </div>

                <div class="button-row success-actions">
                    <button class="btn btn-primary" type="button" @onclick="CloseAndContinueAsync">Close & Continue</button>
                    <button class="btn btn-outline" type="button" @onclick='() => Nav.NavigateTo("/")'>Start New Registration</button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private async Task CloseAndContinueAsync()
    {
        await IframeInterop.NotifyParentAsync("registration.review.pending", new { status = "submitted" });
        Nav.NavigateTo("/");
    }
}
