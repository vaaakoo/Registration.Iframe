@page "/iframe/identification"
@rendermode InteractiveWebAssembly
@implements IAsyncDisposable
@inject IKycService KycService
@inject IUserService UserService
@inject IReferenceDataService ReferenceDataService
@inject IIframeInteropService IframeInterop
@inject IAppEnvironmentService Environment
@inject NavigationManager Nav
@inject PayUnicard.Registration.Iframe.Client.Services.RegistrationState State

<div class="reg-page">
    <div class="reg-card reg-card-wide">
        <div class="reg-logo">
            <img class="reg-logo-mark" src="/images/payunicard_en.svg" alt="PayUnicard" />
        </div>

        @if (!hasStarted)
        {
            <div class="intro-shell">
                <div class="intro-card">
                    <h1 class="reg-title reg-title-centered">Identification</h1>
                    <p class="reg-subtitle reg-subtitle-centered">Before we continue, please prepare the documents required for visual identification.</p>
                    <div class="intro-list">
                        <div class="intro-item"><div class="intro-badge">5</div><div><strong>Around 5 minutes</strong><p>Please keep enough time to finish the identification process in one session.</p></div></div>
                        <div class="intro-item"><div class="intro-badge">ID</div><div><strong>Prepare your document</strong><p>You can use an ID card, residence permit, or passport during verification.</p></div></div>
                        <div class="intro-item"><div class="intro-badge">OK</div><div><strong>Camera and internet</strong><p>Use a stable internet connection and good lighting before you start.</p></div></div>
                    </div>
                </div>
                <div class="button-row intro-actions">
                    <button class="btn btn-primary" type="button" @onclick="StartIdentificationAsync">Next</button>
                </div>
            </div>
        }
        else
        {
            <div class="wizard-shell">
                <h1 class="reg-title wizard-title">Identification</h1>
                <div class="wizard-step-header">
                    @if (wizardStep > 1)
                    {
                        <button class="section-back" type="button" @onclick="PrevStep">Back</button>
                    }
                    <div>
                        <h2 class="wizard-step-title">@CurrentStepTitle</h2>
                        <p class="wizard-step-copy">@CurrentStepSubtitle</p>
                    </div>
                </div>

                @if (Environment.IsMockMode)
                {
                    <div class="alert alert-info">Development mode is enabled. KYC completion can be simulated locally.</div>
                }
                @if (!string.IsNullOrEmpty(errorMsg))
                {
                    <div class="alert alert-danger">@errorMsg</div>
                }

                @if (wizardStep == 1)
                {
                    <div class="wizard-content-shell">
                        <div class="form-stack">
                            <div class="field"><label for="legalCountry">Legal Country</label><select id="legalCountry" @bind="legalCountry"><option value="">Select country</option>@foreach (var country in countries){<option value="@country.CountryID">@country.CountryName</option>}</select></div>
                            <div class="field"><label for="legalCity">City</label><input id="legalCity" @bind="legalCity" /></div>
                            <div class="field"><label for="legalAddress">Address</label><input id="legalAddress" @bind="legalAddress" /></div>
                            <div class="field"><label for="legalPostalCode">Postal Code</label><input id="legalPostalCode" @bind="legalPostal" /></div>
                            <label class="checkbox-row"><input type="checkbox" @bind="sameAsLegal" /><span>Actual address is the same as legal address.</span></label>
                            @if (!sameAsLegal)
                            {
                                <div class="section-divider"></div>
                                <div class="field"><label for="factCountry">Fact Country</label><select id="factCountry" @bind="factCountry"><option value="">Select country</option>@foreach (var country in countries){<option value="@country.CountryID">@country.CountryName</option>}</select></div>
                                <div class="field"><label for="factCity">Fact City</label><input id="factCity" @bind="factCity" /></div>
                                <div class="field"><label for="factAddress">Fact Address</label><input id="factAddress" @bind="factAddress" /></div>
                                <div class="field"><label for="factPostalCode">Fact Postal Code</label><input id="factPostalCode" @bind="factPostal" /></div>
                            }
                        </div>
                        <div class="button-row"><button class="btn btn-outline" type="button" @onclick="ResetIdentification">Cancel</button><button class="btn btn-primary" type="button" @onclick="NextStepAsync" disabled="@(!CanGoStep1)">Next</button></div>
                    </div>
                }
                else if (wizardStep == 2)
                {
                    <div class="wizard-content-shell">
                        <div class="form-stack">
                            <div class="field">
                                <label for="employmentStatus">Employment Status</label>
                                <select id="employmentStatus" @bind="empStatus" @bind:after="OnEmploymentStatusChanged">
                                    <option value="">Select status</option>
                                    @foreach (var status in employmentStatuses)
                                    {
                                        <option value="@status.EmploymentStatusCode">@status.EmploymentStatus</option>
                                    }
                                </select>
                            </div>
                            @if (IsEmployed)
                            {
                                <div class="field">
                                    <label for="workType">Work Type</label>
                                    <select id="workType" @bind="workType" @bind:after="OnWorkTypeChanged">
                                        <option value="">Select work type</option>
                                        @foreach (var work in workTypes)
                                        {
                                            <option value="@work.CustomerEmploymentTypeCode">@work.CustomerEmploymentType</option>
                                        }
                                    </select>
                                </div>
                            }
                            @if (IsEmployed && !IsSelfEmployed)
                            {
                                <div class="field"><label for="employer">Employer</label><input id="employer" @bind="employer" /></div>
                                <div class="field"><label for="workPosition">Position</label><input id="workPosition" @bind="workPosition" /></div>
                            }
                        </div>
                        <div class="button-row"><button class="btn btn-outline" type="button" @onclick="PrevStep">Back</button><button class="btn btn-primary" type="button" @onclick="NextStepAsync" disabled="@(!CanGoStep2)">Next</button></div>
                    </div>
                }
                else if (wizardStep == 3)
                {
                    <div class="wizard-content-shell">
                        <div class="form-stack">
                            <div class="field"><label for="expectedTurnover">Expected Monthly Turnover</label><select id="expectedTurnover" @bind="expectedTurnover"><option value="">Select turnover</option>@foreach (var turnover in turnoverTypes){<option value="@turnover.ExpectedTurnoverCode">@turnover.ExpectedTurnover</option>}</select></div>
                            <div class="field">
                                <label for="annualIncome">Expected Annual Income</label>
                                <select id="annualIncome" @bind="annualIncomeId">
                                    <option value="">Select annual income</option>
                                    @foreach (var income in annualIncomes)
                                    {
                                        <option value="@income.ExpectedAnnualIncomeId">@income.ExpectedAnnualIncomeCode</option>
                                    }
                                </select>
                            </div>
                            <div class="field"><label>Expected Transaction Types</label><div class="purpose-list">@foreach (var purpose in transactionTypes){<label class="checkbox-card"><input type="checkbox" checked="@selectedTransactionTypes.Contains(purpose.ExpectedTransactionsID)" @onchange="args => ToggleTransactionType(purpose.ExpectedTransactionsID, (bool?)args.Value == true)" /><span>@purpose.ExpectedTransactionsCode</span></label>}</div></div>
                        </div>
                        <div class="button-row"><button class="btn btn-outline" type="button" @onclick="PrevStep">Back</button><button class="btn btn-primary" type="button" @onclick="NextStepAsync" disabled="@(!CanGoStep3)">Next</button></div>
                    </div>
                }
                else if (wizardStep == 4)
                {
                    <div class="wizard-content-shell wizard-content-shell-wide">
                        @if (kycLoading)
                        {
                            <div class="alert alert-info">Preparing KYC session...</div>
                        }
                        else if (!string.IsNullOrWhiteSpace(kycFrameUrl) && !kycDone)
                        {
                            <iframe class="kyc-frame" src="@kycFrameUrl" title="KYC Verification"></iframe>
                        }
                        else if (!kycDone)
                        {
                            <div class="summary-card">KYC session is ready. Start document capture and selfie verification in the embedded frame.</div>
                        }
                        @if (Environment.IsMockMode && !kycDone)
                        {
                            <button class="btn btn-outline" type="button" @onclick="SimulateKycCompletionAsync">Simulate KYC Complete</button>
                        }
                        @if (kycDone)
                        {
                            <div class="summary-card"><strong>KYC completed</strong><div>Name: @($"{kycData?.FirstName} {kycData?.LastName}".Trim())</div><div>Document number: @kycData?.DocumentNumber</div><div>Personal number: @kycData?.PersonalNumber</div></div>
                        }
                        <div class="button-row"><button class="btn btn-outline" type="button" @onclick="PrevStep" disabled="@kycLoading">Back</button><button class="btn btn-primary" type="button" @onclick="NextStepAsync" disabled="@(!kycDone)">Next</button></div>
                    </div>
                }
                else if (wizardStep == 5)
                {
                    <div class="wizard-content-shell">
                        <div class="summary-card">
                            <div><strong>Document Type:</strong> @documentType</div>
                            <div><strong>Document Number:</strong> @documentNumber</div>
                            <div><strong>Personal Number:</strong> @personalNumber</div>
                        </div>
                        <div class="form-stack">
                            <div class="field">
                                <label for="documentType">Document Type</label>
                                <input id="documentType" value="@documentType" disabled />
                            </div>
                            <div class="field">
                                <label for="documentNumber">Document Number</label>
                                <input id="documentNumber" value="@documentNumber" disabled />
                            </div>
                            <div class="field">
                                <label for="personalNumber">Personal Number</label>
                                <input id="personalNumber" @bind="personalNumber" @bind:event="oninput" class="@(RequiresPersonalNumber && !IsPersonalNumberValid ? "error" : string.Empty)" />
                                @if (RequiresPersonalNumber && !IsPersonalNumberValid)
                                {
                                    <div class="field-error">Personal number must contain 11 digits.</div>
                                }
                            </div>
                            <div class="form-grid">
                                <div class="field">
                                    <label for="issueDate">Issue Date</label>
                                    <input id="issueDate" type="date" value="@IssueDateInputValue" @onchange="OnIssueDateChanged" />
                                </div>
                                <div class="field">
                                    <label for="expirationDate">Expiration Date</label>
                                    <input id="expirationDate" type="date" value="@ExpirationDateInputValue" @onchange="OnExpirationDateChanged" />
                                </div>
                            </div>
                            <div class="field">
                                <label for="documentIssuingCountry">Document Issuing Country</label>
                                <select id="documentIssuingCountry" @bind="documentIssuingCountry">
                                    <option value="">Select country</option>
                                    @foreach (var country in countries)
                                    {
                                        <option value="@country.CountryID">@country.CountryName</option>
                                    }
                                </select>
                            </div>
                            <div class="field">
                                <label for="firstName">First Name</label>
                                <input id="firstName" value="@KycFirstName" disabled />
                            </div>
                            <div class="field">
                                <label for="lastName">Last Name</label>
                                <input id="lastName" value="@KycLastName" disabled />
                            </div>
                            <div class="field">
                                <label for="citizenshipCountry">Citizenship</label>
                                <select id="citizenshipCountry" @bind="citizenshipCountry">
                                    <option value="">Select country</option>
                                    @foreach (var country in countries)
                                    {
                                        <option value="@country.CountryID">@country.CountryName</option>
                                    }
                                </select>
                            </div>
                            @if (!IsGeorgianCitizenship && !string.IsNullOrWhiteSpace(citizenshipCountry))
                            {
                                <div class="field">
                                    <label for="transitPurpose">Transit purpose planned</label>
                                    <select id="transitPurpose" value="@TransitPurposeValue" @onchange="OnTransitPurposeChanged">
                                        <option value="">Select option</option>
                                        <option value="true">Yes</option>
                                        <option value="false">No</option>
                                    </select>
                                </div>
                                <div class="field">
                                    <label>Usage Purposes</label>
                                    <div class="purpose-list">
                                        @foreach (var purpose in usagePurposes)
                                        {
                                            <label class="checkbox-card">
                                                <input type="checkbox" checked="@selectedPurposes.Contains(purpose.UsageID)" @onchange="args => TogglePurpose(purpose.UsageID, (bool?)args.Value == true)" />
                                                <span>@purpose.UsagePurposeText</span>
                                            </label>
                                        }
                                    </div>
                                </div>
                            }
                            <div class="field">
                                <label for="birthCountry">Birth Country</label>
                                <select id="birthCountry" @bind="birthCountry">
                                    <option value="">Select country</option>
                                    @foreach (var country in countries)
                                    {
                                        <option value="@country.CountryID">@country.CountryName</option>
                                    }
                                </select>
                            </div>
                            <div class="field">
                                <label for="birthCity">Birth City</label>
                                <input id="birthCity" @bind="birthCity" />
                            </div>
                            <div class="field">
                                <label for="birthDate">Birth Date</label>
                                <input id="birthDate" type="date" value="@BirthDateInputValue" @onchange="OnBirthDateChanged" />
                            </div>
                            <div class="field">
                                <label>Sex</label>
                                <div class="radio-group">
                                    <label class="radio-option">
                                        <input type="radio" name="sex" value="female" checked="@string.Equals(sex, "female", StringComparison.OrdinalIgnoreCase)" @onchange="OnSexChanged" />
                                        <span>Female</span>
                                    </label>
                                    <label class="radio-option">
                                        <input type="radio" name="sex" value="male" checked="@string.Equals(sex, "male", StringComparison.OrdinalIgnoreCase)" @onchange="OnSexChanged" />
                                        <span>Male</span>
                                    </label>
                                </div>
                            </div>
                            <div class="field">
                                <label for="dualCitizen">Dual Citizen</label>
                                <select id="dualCitizen" @bind="dualCitizen">
                                    <option value="0">No</option>
                                    <option value="1">Yes</option>
                                </select>
                            </div>
                            @if (dualCitizen == 1)
                            {
                                <div class="field">
                                    <label for="secondCitizenship">Second Citizenship Country</label>
                                    <select id="secondCitizenship" @bind="secondCitizenshipCountry">
                                        <option value="0">Select country</option>
                                        @foreach (var country in countries)
                                        {
                                            <option value="@country.CountryID">@country.CountryName</option>
                                        }
                                    </select>
                                </div>
                            }
                            @if (Environment.IsMockMode && AdditionalBlockingReasons.Count > 0)
                            {
                                <div class="form-helper">
                                    <strong>Still missing:</strong>
                                    <ul>
                                        @foreach (var reason in AdditionalBlockingReasons)
                                        {
                                            <li>@reason</li>
                                        }
                                    </ul>
                                </div>
                            }
                        </div>
                        <div class="button-row"><button class="btn btn-outline" type="button" @onclick="PrevStep">Back</button><button class="btn btn-primary" type="button" @onclick="NextStepAsync" disabled="@(!CanGoStep5)">Next</button></div>
                    </div>
                }
                else
                {
                    <div class="wizard-content-shell">
                        <div class="summary-card">
                            <div><strong>Document Type:</strong> @documentType</div>
                            <div><strong>Personal Number:</strong> @personalNumber</div>
                            <div><strong>Name:</strong> @($"{KycFirstName} {KycLastName}".Trim())</div>
                            <div><strong>Birth Date:</strong> @BirthDateDisplay</div>
                        </div>
                        <div class="doc-shell">
                            <p class="doc-title">Uploaded documents</p>
                            <div class="doc-grid">
                                @if (!string.IsNullOrWhiteSpace(DocumentFrontDisplay))
                                {
                                    <img src="@DocumentFrontDisplay" alt="Document front" class="doc-image" />
                                }
                                @if (IsIdDocument && !string.IsNullOrWhiteSpace(DocumentBackDisplay))
                                {
                                    <img src="@DocumentBackDisplay" alt="Document back" class="doc-image" />
                                }
                            </div>
                        </div>
                        <label class="checkbox-row">
                            <input type="checkbox" @bind="agreeFinalTerms" />
                            <span>
                                I agree to the
                                <a href="/info-page/terms-of-use?open=0" target="_blank" rel="noreferrer"> terms of service</a>.
                            </span>
                        </label>
                        @if (submitSuccess)
                        {
                            <div class="alert alert-success">Registration submitted successfully.</div>
                            <button class="btn btn-primary" type="button" @onclick='() => Nav.NavigateTo("/success")'>Continue</button>
                        }
                        else
                        {
                            <div class="button-row"><button class="btn btn-outline" type="button" @onclick="PrevStep">Back</button><button class="btn btn-primary" type="button" @onclick="SubmitAllAsync" disabled="@(!CanSubmit)">@if (loading){<span class="spinner"></span>}<span>Submit Application</span></button></div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private const int GeorgiaCountryId = 79;
    private int wizardStep = 1;
    private bool loading, submitSuccess, hasStarted, sameAsLegal = true, kycDone, kycLoading, identificationStartedNotified, additionalDataPrefilled, agreeFinalTerms, customerRegistrationSubmitted;
    private bool? isTransitPurpose;
    private int dualCitizen, secondCitizenshipCountry;
    private DateOnly? issueDateValue;
    private DateOnly? expirationDateValue;
    private DateOnly? birthDateValue;
    private string errorMsg = string.Empty, legalCountry = string.Empty, legalCity = string.Empty, legalAddress = string.Empty, legalPostal = string.Empty, factCountry = string.Empty, factCity = string.Empty, factAddress = string.Empty, factPostal = string.Empty, empStatus = string.Empty, workType = string.Empty, employer = string.Empty, workPosition = string.Empty, expectedTurnover = string.Empty, annualIncomeId = string.Empty, kycSessionId = string.Empty, kycListenerId = string.Empty;
    private string documentNumber = string.Empty, personalNumber = string.Empty, documentIssuingCountry = string.Empty, citizenshipCountry = string.Empty, birthCountry = string.Empty, birthCity = string.Empty, documentType = string.Empty, sex = "female";
    private string? kycFrameUrl;
    private IDisposable? kycCallbackReference;
    private CloseSessionResponse? kycData;
    private List<CitizenshipCountry> countries = [];
    private List<EmploymentStatusType> employmentStatuses = [];
    private List<WorkType> workTypes = [];
    private List<ExpectedTurnoverType> turnoverTypes = [];
    private List<ExpectedTransactionType> transactionTypes = [];
    private List<AnnualIncomeType> annualIncomes = [];
    private List<UsagePurpose> usagePurposes = [];
    private List<int> selectedTransactionTypes = [];
    private List<int> selectedPurposes = [];

    private bool CanGoStep1 => !string.IsNullOrWhiteSpace(legalCountry) && !string.IsNullOrWhiteSpace(legalCity) && !string.IsNullOrWhiteSpace(legalAddress) && !string.IsNullOrWhiteSpace(legalPostal) && (sameAsLegal || (!string.IsNullOrWhiteSpace(factCountry) && !string.IsNullOrWhiteSpace(factCity) && !string.IsNullOrWhiteSpace(factAddress) && !string.IsNullOrWhiteSpace(factPostal)));
    private bool IsEmployed => string.Equals(empStatus, "Employed", StringComparison.OrdinalIgnoreCase);
    private bool IsSelfEmployed => workType.Contains("Self", StringComparison.OrdinalIgnoreCase) || workType.Contains("Self-employed", StringComparison.OrdinalIgnoreCase);
    private bool CanGoStep2 => !string.IsNullOrWhiteSpace(empStatus)
        && (!IsEmployed || !string.IsNullOrWhiteSpace(workType))
        && (!IsEmployed || IsSelfEmployed || (!string.IsNullOrWhiteSpace(employer) && !string.IsNullOrWhiteSpace(workPosition)));
    private bool CanGoStep3 => !string.IsNullOrWhiteSpace(expectedTurnover) && !string.IsNullOrWhiteSpace(annualIncomeId) && selectedTransactionTypes.Count > 0;
    private bool IsGeorgianCitizenship => ParseNullableInt(citizenshipCountry) == GeorgiaCountryId;
    private bool IsIdDocument => IsDocumentTypeId(documentType);
    private bool RequiresPersonalNumber => IsGeorgianCitizenship || IsIdDocument;
    private bool CanGoStep5 =>
        !string.IsNullOrWhiteSpace(documentNumber)
        && (!RequiresPersonalNumber || IsPersonalNumberValid)
        && issueDateValue is not null
        && expirationDateValue is not null
        && !string.IsNullOrWhiteSpace(documentIssuingCountry)
        && !string.IsNullOrWhiteSpace(citizenshipCountry)
        && !string.IsNullOrWhiteSpace(birthCountry)
        && !string.IsNullOrWhiteSpace(birthCity)
        && birthDateValue is not null
        && !string.IsNullOrWhiteSpace(sex)
        && (dualCitizen == 0 || secondCitizenshipCountry > 0)
        && (IsGeorgianCitizenship || (isTransitPurpose is not null && selectedPurposes.Count > 0));
    private bool CanSubmit => agreeFinalTerms && !loading;
    private string CurrentStepTitle => wizardStep switch { 1 => "Legal Address", 2 => "Employment", 3 => "Relationship with Bank", 4 => "Identification", 5 => "Additional Data", _ => "Check Data" };
    private string CurrentStepSubtitle => wizardStep switch { 1 => "Please enter your legal address. If your factual address is different, add it as well.", 2 => "Tell us about your current employment situation.", 3 => "This information is required for compliance review.", 4 => "Complete document scanning and selfie verification.", 5 => "Review the data received from KYC and add any missing details.", _ => "Confirm all information before final submission." };
    private string LegalCountryName => GetCountryName(legalCountry);
    private string SelectedTransactionTypeSummary => selectedTransactionTypes.Count == 0 ? "Not selected" : string.Join(", ", transactionTypes.Where(type => selectedTransactionTypes.Contains(type.ExpectedTransactionsID)).Select(type => type.ExpectedTransactionsCode));
    private string SelectedUsagePurposeSummary => selectedPurposes.Count == 0 ? "Not selected" : string.Join(", ", usagePurposes.Where(type => selectedPurposes.Contains(type.UsageID)).Select(type => type.UsagePurposeText));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var countriesTask = ReferenceDataService.GetCitizenshipCountriesAsync();
            var employmentTask = ReferenceDataService.GetCustomerEmploymentStatusTypesAsync();
            var workTask = ReferenceDataService.GetCustomerWorkTypesAsync();
            var turnoverTask = ReferenceDataService.GetExpectedTransactionTypesAsync();
            var incomeTask = ReferenceDataService.GetCustomerAnnualIncomeTypesAsync();
            var purposeTask = ReferenceDataService.GetCustomerUsagePurposeAsync();

            await Task.WhenAll(countriesTask, employmentTask, workTask, turnoverTask, incomeTask, purposeTask);

            countries = (await countriesTask)?.Countries ?? [];
            employmentStatuses = (await employmentTask)?.Statuses ?? [];
            workTypes = (await workTask)?.Types ?? [];

            var turnoverData = await turnoverTask;
            turnoverTypes = turnoverData?.ExpectedTurnoverTypes ?? [];
            transactionTypes = turnoverData?.ExpectedTransactionTypes ?? [];

            annualIncomes = (await incomeTask)?.ExpectedAnnualIncomes ?? [];
            usagePurposes = (await purposeTask)?.CustomerUsagePurposes ?? [];

            EnsureCountryDefaults();

            if (State.KycData is not null)
            {
                kycData = State.KycData;
                kycDone = true;
                ApplyKycDefaults(kycData);
            }
        }
        catch (Exception ex)
        {
            errorMsg = $"Failed to load presentation data: {ex.Message}";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || identificationStartedNotified)
        {
            return;
        }

        try
        {
            await IframeInterop.NotifyParentAsync("identification.started");
            identificationStartedNotified = true;
        }
        catch (InvalidOperationException)
        {
        }
    }

    private async Task StartIdentificationAsync()
    {
        hasStarted = true;
        await IframeInterop.NotifyParentAsync("identification.start.clicked");
    }

    private void ResetIdentification()
    {
        hasStarted = false;
        wizardStep = 1;
        errorMsg = string.Empty;
        customerRegistrationSubmitted = false;
        submitSuccess = false;
        agreeFinalTerms = false;
    }

    private void PrevStep()
    {
        errorMsg = string.Empty;
        if (wizardStep > 1)
        {
            wizardStep--;
        }
    }

    private async Task NextStepAsync()
    {
        errorMsg = string.Empty;

        if (wizardStep == 3)
        {
            var submitted = await SubmitCustomerRegistrationAsync();
            if (!submitted)
            {
                return;
            }

            await OpenKycSessionAsync();
        }

        if (wizardStep < 6)
        {
            wizardStep++;
        }
    }

    private void TogglePurpose(int id, bool isSelected)
    {
        if (isSelected)
        {
            if (!selectedPurposes.Contains(id))
            {
                selectedPurposes.Add(id);
            }
            return;
        }

        selectedPurposes.Remove(id);
    }

    private void ToggleTransactionType(int id, bool isSelected)
    {
        if (isSelected)
        {
            if (!selectedTransactionTypes.Contains(id))
            {
                selectedTransactionTypes.Add(id);
            }
            return;
        }

        selectedTransactionTypes.Remove(id);
    }

    private async Task OpenKycSessionAsync()
    {
        if (!string.IsNullOrWhiteSpace(kycFrameUrl) || kycDone || kycLoading)
        {
            return;
        }

        kycLoading = true;
        try
        {
            await KycService.CheckSessionLimitWebAsync();
            var session = await KycService.OpenSessionAsync();
            kycFrameUrl = session?.FrameUrl;
            kycSessionId = session?.SessionId ?? string.Empty;
            State.KycData = null;
            additionalDataPrefilled = false;
            documentType = string.Empty;
            documentNumber = string.Empty;
            personalNumber = string.Empty;
            issueDateValue = null;
            expirationDateValue = null;
            birthDateValue = null;
            sex = "female";

            if (session?.SkipKycSession == true)
            {
                var data = await KycService.GetSessionDataAsync(session.SessionId);
                kycData = data?.Data.FirstOrDefault() is { } existingData ? ToCloseSessionData(existingData) : null;
                State.KycData = kycData;
                kycDone = kycData is not null;
                if (kycData is not null)
                {
                    ApplyKycDefaults(kycData);
                }
                return;
            }

            if (!string.IsNullOrWhiteSpace(kycFrameUrl))
            {
                var callback = DotNetObjectReference.Create(this);
                kycCallbackReference = callback;
                kycListenerId = await IframeInterop.RegisterKycListenerAsync(callback);
            }
        }
        catch (Exception ex)
        {
            errorMsg = $"Failed to open KYC session: {ex.Message}";
        }
        finally
        {
            kycLoading = false;
        }
    }

    [JSInvokable]
    public async Task HandleKycMessage(string origin, string eventName)
    {
        await CompleteKycAsync($"KYC callback received from {origin} ({eventName}).");
    }

    private Task SimulateKycCompletionAsync() => CompleteKycAsync("Mock KYC completion was triggered.");

    private async Task CompleteKycAsync(string sourceDescription)
    {
        try
        {
            var result = await KycService.CloseSessionAsync(kycSessionId);
            kycData = result;
            State.KycData = result;
            kycDone = result is not null;
            if (result is not null)
            {
                ApplyKycDefaults(result);
            }
            await IframeInterop.NotifyParentAsync("identification.kyc.completed", new { sessionId = kycSessionId, source = sourceDescription });
        }
        catch (Exception ex)
        {
            errorMsg = $"Failed to close KYC session: {ex.Message}";
        }
    }

    private async Task SubmitAllAsync()
    {
        loading = true;
        errorMsg = string.Empty;

        try
        {
            if (!customerRegistrationSubmitted)
            {
                var submitted = await SubmitCustomerRegistrationAsync();
                if (!submitted)
                {
                    return;
                }
            }

            if (!IsGeorgianCitizenship)
            {
                await UserService.ChangeCustomerAsync(new ChangeCustomerRequest
                {
                    DocumentRegisterCountryId = ParseNullableInt(documentIssuingCountry) ?? kycData?.DocumentIssuingCountryID,
                    ExpectedAnualIncomeCode = annualIncomeId,
                    IsTransitUsagePlanned = isTransitPurpose,
                    IsPartnerSelected = selectedPurposes.Contains(1),
                    IsGeorgiaSelected = selectedPurposes.Contains(2),
                    IsNoLocalAlternative = selectedPurposes.Contains(3),
                    IsPayUnicardUsagePlanned = selectedPurposes.Contains(4)
                });
            }

            var finishRequest = new FinishCustomerRegistrationRequest
            {
                DocumentType = string.IsNullOrWhiteSpace(documentType) ? (kycData?.DocumetType ?? "ID_CARD") : documentType,
                Name = KycFirstName,
                Surname = KycLastName,
                PersonalID = string.IsNullOrWhiteSpace(personalNumber) ? (kycData?.PersonalNumber ?? string.Empty) : personalNumber,
                DocumentNumber = string.IsNullOrWhiteSpace(documentNumber) ? (kycData?.DocumentNumber ?? string.Empty) : documentNumber,
                DocumentFrontSide = kycData?.DocumentFrontSide ?? string.Empty,
                DocumentFrontSideName = "front.jpg",
                DocumentBackSide = kycData?.DocumentBackSide ?? string.Empty,
                DocumentBackSideName = "back.jpg",
                CustomerSelf = kycData?.SelfImages.FirstOrDefault() ?? string.Empty,
                CustomerSelfName = "selfie.jpg",
                Sex = ParseSex(sex),
                BirthDate = birthDateValue?.ToString("yyyy-MM-dd") ?? kycData?.BirthDate ?? string.Empty,
                IssueDate = issueDateValue?.ToString("yyyy-MM-dd") ?? kycData?.IssueDate ?? string.Empty,
                ValidTo = expirationDateValue?.ToString("yyyy-MM-dd") ?? kycData?.ExpirationDate ?? string.Empty,
                CitizenshipCountryID = ParseNullableInt(citizenshipCountry) ?? kycData?.CountryID ?? 79,
                BirthCity = birthCity.Trim(),
                BirthCountryId = ParseNullableInt(birthCountry) ?? kycData?.CountryID ?? 79,
                DualCitizen = dualCitizen,
                SecondaryCitizenshipCountryID = secondCitizenshipCountry
            };

            await UserService.FinishCustomerRegistrationAsync(finishRequest);
            submitSuccess = true;
            await IframeInterop.NotifyParentAsync("registration.completed");
        }
        catch (Exception ex)
        {
            errorMsg = $"Submission failed: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task<bool> SubmitCustomerRegistrationAsync()
    {
        try
        {
            var customerRegistration = BuildCustomerRegistrationRequest();
            State.Customer = customerRegistration;
            var response = await UserService.CustomerRegistrationAsync(customerRegistration);
            customerRegistrationSubmitted = response?.Success == true;
            if (!customerRegistrationSubmitted)
            {
                errorMsg = "Customer registration failed. Please try again.";
            }

            return customerRegistrationSubmitted;
        }
        catch (Exception ex)
        {
            errorMsg = $"Customer registration failed: {ex.Message}";
            return false;
        }
    }

    private CustomerRegistrationRequest BuildCustomerRegistrationRequest()
        => new()
        {
            LegalCountryID = ParseNullableInt(legalCountry),
            LegalCity = legalCity.Trim(),
            LegalAddress = legalAddress.Trim(),
            LegalPostalCode = legalPostal.Trim(),
            FactCountryID = sameAsLegal ? ParseNullableInt(legalCountry) : ParseNullableInt(factCountry),
            FactCity = sameAsLegal ? legalCity.Trim() : factCity.Trim(),
            FactAddress = sameAsLegal ? legalAddress.Trim() : factAddress.Trim(),
            FactPostalCode = sameAsLegal ? legalPostal.Trim() : factPostal.Trim(),
            Employer = employer.Trim(),
            EmploymentStatusCode = empStatus,
            EmploymentTypeCode = workType,
            WorkPosition = workPosition.Trim(),
            ExpectedTurnoverCode = expectedTurnover,
            ExpectedAnualIncomeCode = annualIncomeId,
            ExpectedTransactionTypes = [.. selectedTransactionTypes],
            DocumentRegisterCountryId = ParseNullableInt(documentIssuingCountry) ?? kycData?.DocumentIssuingCountryID,
            IsTransitUsagePlanned = IsGeorgianCitizenship ? null : isTransitPurpose,
            IsPartnerSelected = selectedPurposes.Contains(1),
            IsGeorgiaSelected = selectedPurposes.Contains(2),
            IsNoLocalAlternative = selectedPurposes.Contains(3),
            IsPayUnicardUsagePlanned = selectedPurposes.Contains(4)
        };

    private void OnEmploymentStatusChanged()
    {
        if (!IsEmployed)
        {
            workType = string.Empty;
            employer = string.Empty;
            workPosition = string.Empty;
            return;
        }

        if (IsSelfEmployed)
        {
            employer = string.Empty;
            workPosition = string.Empty;
        }
    }

    private void OnWorkTypeChanged()
    {
        if (IsSelfEmployed)
        {
            employer = string.Empty;
            workPosition = string.Empty;
        }
    }

    private void OnIssueDateChanged(ChangeEventArgs args)
    {
        issueDateValue = DateOnly.TryParse(args.Value?.ToString(), out var parsedDate) ? parsedDate : null;
    }

    private void OnExpirationDateChanged(ChangeEventArgs args)
    {
        expirationDateValue = DateOnly.TryParse(args.Value?.ToString(), out var parsedDate) ? parsedDate : null;
    }

    private void OnBirthDateChanged(ChangeEventArgs args)
    {
        birthDateValue = DateOnly.TryParse(args.Value?.ToString(), out var parsedDate) ? parsedDate : null;
    }

    private void OnSexChanged(ChangeEventArgs args)
    {
        sex = args.Value?.ToString() ?? string.Empty;
    }

    private void OnTransitPurposeChanged(ChangeEventArgs args)
    {
        var value = args.Value?.ToString();
        if (string.IsNullOrWhiteSpace(value))
        {
            isTransitPurpose = null;
            return;
        }

        isTransitPurpose = string.Equals(value, "true", StringComparison.OrdinalIgnoreCase);
    }

    private void EnsureCountryDefaults()
    {
        if (countries.Count == 0)
        {
            return;
        }

        var preferredId = countries[0].CountryID;

        if (string.IsNullOrWhiteSpace(citizenshipCountry))
        {
            citizenshipCountry = preferredId.ToString();
        }

        if (string.IsNullOrWhiteSpace(birthCountry))
        {
            birthCountry = preferredId.ToString();
        }

        if (string.IsNullOrWhiteSpace(documentIssuingCountry))
        {
            documentIssuingCountry = preferredId.ToString();
        }
    }

    private void ApplyKycDefaults(CloseSessionResponse data)
    {
        if (additionalDataPrefilled)
        {
            return;
        }

        documentType = string.IsNullOrWhiteSpace(documentType) ? data.DocumetType : documentType;
        documentNumber = string.IsNullOrWhiteSpace(documentNumber) ? data.DocumentNumber : documentNumber;
        personalNumber = string.IsNullOrWhiteSpace(personalNumber) ? data.PersonalNumber : personalNumber;

        issueDateValue ??= ParseDateOnly(data.IssueDate) ?? ParseDateOnly(data.IssueDateTime);
        expirationDateValue ??= ParseDateOnly(data.ExpirationDate);
        birthDateValue ??= ParseDateOnly(data.BirthDate);

        if (string.IsNullOrWhiteSpace(citizenshipCountry) && data.CountryID > 0)
        {
            citizenshipCountry = data.CountryID.ToString();
        }

        if (string.IsNullOrWhiteSpace(documentIssuingCountry) && data.DocumentIssuingCountryID is not null)
        {
            documentIssuingCountry = data.DocumentIssuingCountryID.Value.ToString();
        }

        if (string.IsNullOrWhiteSpace(birthCountry) && data.CountryID > 0)
        {
            birthCountry = data.CountryID.ToString();
        }

        if (string.IsNullOrWhiteSpace(birthCity))
        {
            birthCity = legalCity;
        }

        sex = NormalizeSex(data.Sex);
        additionalDataPrefilled = true;
    }

    private string KycFirstName => string.IsNullOrWhiteSpace(kycData?.FirstName) ? string.Empty : kycData.FirstName;

    private string KycLastName => string.IsNullOrWhiteSpace(kycData?.LastName) ? string.Empty : kycData.LastName;

    private string IssueDateInputValue => issueDateValue?.ToString("yyyy-MM-dd") ?? string.Empty;

    private string ExpirationDateInputValue => expirationDateValue?.ToString("yyyy-MM-dd") ?? string.Empty;

    private string BirthDateInputValue => birthDateValue?.ToString("yyyy-MM-dd") ?? string.Empty;

    private string BirthDateDisplay => birthDateValue?.ToString("yyyy-MM-dd")
        ?? ParseDateOnly(kycData?.BirthDate)?.ToString("yyyy-MM-dd")
        ?? string.Empty;

    private string TransitPurposeValue => isTransitPurpose is null ? string.Empty : (isTransitPurpose.Value ? "true" : "false");

    private bool IsPersonalNumberValid
    {
        get
        {
            if (!RequiresPersonalNumber)
            {
                return true;
            }

            if (string.IsNullOrWhiteSpace(personalNumber))
            {
                return false;
            }

            var trimmed = personalNumber.Trim();
            if (IsGeorgianCitizenship)
            {
                return trimmed.Length == 11 && trimmed.All(char.IsDigit);
            }

            return trimmed.Length > 0;
        }
    }

    private List<string> AdditionalBlockingReasons => GetAdditionalBlockingReasons();

    private List<string> GetAdditionalBlockingReasons()
    {
        var reasons = new List<string>();

        if (string.IsNullOrWhiteSpace(documentNumber))
        {
            reasons.Add("Document number is required.");
        }

        if (RequiresPersonalNumber && !IsPersonalNumberValid)
        {
            reasons.Add("Personal number must contain 11 digits.");
        }

        if (issueDateValue is null)
        {
            reasons.Add("Issue date is required.");
        }

        if (expirationDateValue is null)
        {
            reasons.Add("Expiration date is required.");
        }

        if (string.IsNullOrWhiteSpace(documentIssuingCountry))
        {
            reasons.Add("Document issuing country is required.");
        }

        if (string.IsNullOrWhiteSpace(citizenshipCountry))
        {
            reasons.Add("Citizenship is required.");
        }

        if (string.IsNullOrWhiteSpace(birthCountry))
        {
            reasons.Add("Birth country is required.");
        }

        if (string.IsNullOrWhiteSpace(birthCity))
        {
            reasons.Add("Birth city is required.");
        }

        if (birthDateValue is null)
        {
            reasons.Add("Birth date is required.");
        }

        if (string.IsNullOrWhiteSpace(sex))
        {
            reasons.Add("Sex is required.");
        }

        if (dualCitizen == 1 && secondCitizenshipCountry <= 0)
        {
            reasons.Add("Second citizenship country is required.");
        }

        if (!IsGeorgianCitizenship)
        {
            if (isTransitPurpose is null)
            {
                reasons.Add("Transit purpose selection is required.");
            }

            if (selectedPurposes.Count == 0)
            {
                reasons.Add("Select at least one usage purpose.");
            }
        }

        return reasons;
    }

    private string DocumentFrontDisplay => NormalizeImageSource(kycData?.DocumentFrontSide);

    private string DocumentBackDisplay => NormalizeImageSource(kycData?.DocumentBackSide);

    private static string NormalizeImageSource(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        if (value.StartsWith("data:", StringComparison.OrdinalIgnoreCase)
            || value.StartsWith("http", StringComparison.OrdinalIgnoreCase)
            || value.StartsWith("blob:", StringComparison.OrdinalIgnoreCase))
        {
            return value;
        }

        return $"data:image/jpeg;base64,{value}";
    }

    private static string NormalizeSex(string? value)
    {
        if (string.Equals(value, "male", StringComparison.OrdinalIgnoreCase) || value == "1")
        {
            return "male";
        }

        if (string.Equals(value, "female", StringComparison.OrdinalIgnoreCase) || value == "0")
        {
            return "female";
        }

        return "female";
    }

    private static bool IsDocumentTypeId(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return false;
        }

        var normalized = value.Replace("-", "_", StringComparison.OrdinalIgnoreCase).Trim().ToUpperInvariant();
        return normalized is "ID" or "ID_CARD" or "IDCARD";
    }

    private static DateOnly? ParseDateOnly(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        if (DateOnly.TryParse(value, out var parsed))
        {
            return parsed;
        }

        return DateTime.TryParse(value, out var dateTime)
            ? DateOnly.FromDateTime(dateTime)
            : null;
    }

    private string GetCountryName(string? countryId)
        => countries.FirstOrDefault(country => country.CountryID.ToString() == countryId)?.CountryName ?? "Not selected";

    private string GetEmploymentStatusLabel(string? statusCode)
        => employmentStatuses.FirstOrDefault(status => status.EmploymentStatusCode == statusCode)?.EmploymentStatus ?? "Not selected";

    private string GetWorkTypeLabel(string? workTypeCode)
        => workTypes.FirstOrDefault(type => type.CustomerEmploymentTypeCode == workTypeCode)?.CustomerEmploymentType ?? "Not selected";

    private string GetTurnoverLabel(string? turnoverCode)
        => turnoverTypes.FirstOrDefault(type => type.ExpectedTurnoverCode == turnoverCode)?.ExpectedTurnover ?? "Not selected";

    private string GetAnnualIncomeLabel(string? incomeId)
        => annualIncomes.FirstOrDefault(income => income.ExpectedAnnualIncomeId.ToString() == incomeId)?.ExpectedAnnualIncomeCode ?? "Not selected";

    private static int? ParseNullableInt(string? value)
        => int.TryParse(value, out var parsed) ? parsed : null;

    private static int ParseSex(string? value)
        => string.Equals(value, "male", StringComparison.OrdinalIgnoreCase) || value == "1" ? 1 : 0;

