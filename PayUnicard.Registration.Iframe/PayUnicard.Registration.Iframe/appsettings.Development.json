{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "App": {
    "Mode": "Development",
    "UseMockServices": true,
    "EnableParentMessaging": true,
    "EnableRecaptcha": false
  },
  "Iframe": {
    "AllowedParentOrigins": [
      "http://localhost:3000",
      "https://localhost:5001"
    ],
    "AllowedKycOrigins": [
      "https://api.kvalifika.com",
      "https://sdk.kvalifika.com",
      "http://localhost:3000",
      "https://localhost:5001"
    ],
    "CompletionEventNames": [
      "KYC_COMPLETED",
      "KVALIFIKA_COMPLETED",
      "verificationComplete"
    ]
  }
}
