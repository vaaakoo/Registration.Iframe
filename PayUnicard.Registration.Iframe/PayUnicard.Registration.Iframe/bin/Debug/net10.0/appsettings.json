{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "App": {
    "Mode": "Production",
    "UseMockServices": false,
    "EnableParentMessaging": true,
    "EnableRecaptcha": false
  },
  "WalletApi": {
    "BaseUrl": "https://papi.payunicard.ge"
  },
  "GoogleRecaptcha": {
    "SiteKey": ""
  },
  "Iframe": {
    "AllowedParentOrigins": [],
    "AllowedKycOrigins": [
      "https://api.kvalifika.com",
      "https://sdk.kvalifika.com"
    ],
    "CompletionEventNames": [
      "KYC_COMPLETED",
      "KVALIFIKA_COMPLETED",
      "verificationComplete"
    ]
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      },
      "Https": {
        "Url": "https://0.0.0.0:5001"
      }
    }
  }
}
